# .gitignore — egmcp workspace

# Build artefacts
bin/
web/dist/
web/node_modules/
**/*.test
**/*.out
coverage.txt
coverage.html

# Local data — secrets stay local
data/
configs/admin.local.yaml
configs/instances/*.local.yaml
*.local

# Editor / OS
.idea/
.vscode/
.DS_Store
Thumbs.db
*.swp
*.tmp

# Secrets — never commit
*.pem
*.key
.env
.env.*
!.env.example

# Docker
docker-compose.override.yml

# Generated docs
CHANGELOG.local.md
